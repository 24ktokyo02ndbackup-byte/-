-- << Auto Equip Loop >>
RS.Heartbeat:Connect(function()
    local char = localplayer.Character
    if not char then return end

    local function doAutoEquip(equip)
        if not equip or type(equip) ~= "table" then return end

        local equippedTool = char:FindFirstChildOfClass("Tool")
        if equippedTool then
            local toolInList = false
            for gunName, selected in pairs(equip) do
                if selected and gunName and equippedTool.Name:lower():match(gunName:lower()) then
                    toolInList = true
                    break
                end
            end
            if not toolInList then
                equippedTool.Parent = localplayer.Backpack
            end
        end

        for gunName, selected in pairs(equip) do
            if selected and gunName then
                local alreadyEquipped = false
                for _, item in ipairs(char:GetChildren()) do
                    if item:IsA("Tool") and item.Name:lower():match(gunName:lower()) then
                        alreadyEquipped = true
                        break
                    end
                end
                if not alreadyEquipped then
                    for _, item in ipairs(localplayer.Backpack:GetChildren()) do
                        if item:IsA("Tool") and item.Name:lower():match(gunName:lower()) then
                            item.Parent = char
                            break
                        end
                    end
                end
            end
        end
    end

    if Hollow.Ragebot.AutoEquipEnabled and Hollow.Ragebot.Autofire and LockedOnRagebot and CurrentRagebotTarget then
        doAutoEquip(Hollow.Ragebot.AutoEquip)
    elseif Hollow.Forcehit.AutoEquipEnabled and LockedOnForceHit and CurrentForceHitTarget then
        doAutoEquip(Hollow.Forcehit.AutoEquip)
    end
end)
