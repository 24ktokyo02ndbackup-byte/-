local experimentalAngle = 0

local followRestoring = false


RS.RenderStepped:Connect(function(dt)
    if not Hollow.FollowTarget.Enabled then
        if desyncActive then desyncreset() end
        return
    end

    if not localplayer.Character or not localplayer.Character:FindFirstChild("HumanoidRootPart") then return end

    local target = GetFollowTarget()

    if not target or CheckIsDead(target) or (Hollow.Checks.KOcheck and CheckIsKO(target)) then
        if not followRestoring then
            followRestoring = true
            task.spawn(function()
                if Hollow.FollowTarget.Method == "Desync" then
                    desyncreset()
                elseif Hollow.FollowTarget.Method == "Teleport" then
                    task.wait(0.25)
                    RestoreSavedPosition()
                end
                followRestoring = false
            end)
        end
        return
    end

    if not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then
        if not followRestoring then
            followRestoring = true
            task.spawn(function()
                if Hollow.FollowTarget.Method == "Desync" then
                    desyncreset()
                elseif Hollow.FollowTarget.Method == "Teleport" then
                    task.wait(0.25)
                    RestoreSavedPosition()
                end
                followRestoring = false
            end)
        end
        return
    end

    followRestoring = false

    local hrp = localplayer.Character.HumanoidRootPart
    local tRoot = target.Character.HumanoidRootPart

    if Hollow.FollowTarget.Method == "Teleport" and not followWasActive then
        SavedPositionBeforeFollow = hrp.CFrame
        followWasActive = true
        hrp.CFrame = CFrame.new(tRoot.Position)
    end

    local mode = Hollow.FollowTarget.Mode
    local offset

    if mode == "Random" then
        local radius = math.random(2, math.max(2, Hollow.FollowTarget.Radius))
        local height = math.random(0, math.max(0, Hollow.FollowTarget.Height))
        local angle = math.random() * math.pi * 2
        offset = Vector3.new(math.cos(angle) * radius, height, math.sin(angle) * radius)

    elseif mode == "Experimental" then
        local radius = math.random(2, math.max(2, Hollow.FollowTarget.Radius))
        local height = math.random(0, math.max(0, Hollow.FollowTarget.Height))
        offset = Vector3.new(math.random(-radius, radius), height, math.random(-radius, radius))

    else -- Strafe
        local angle = tick() * Hollow.FollowTarget.Speed
        offset = Vector3.new(
            math.cos(angle) * Hollow.FollowTarget.Radius,
            Hollow.FollowTarget.Height,
            math.sin(angle) * Hollow.FollowTarget.Radius
        )
        local newPos = tRoot.Position + offset
        if Hollow.FollowTarget.Method == "Teleport" then
            hrp.CFrame = CFrame.new(newPos)
        else
            desynccframe(CFrame.new(newPos))
        end
        return
    end

    local newPos = tRoot.Position + offset
    if Hollow.FollowTarget.Method == "Teleport" then
        hrp.CFrame = CFrame.new(newPos)
    else
        desynccframe(CFrame.new(newPos))
    end
end)

