function CheckIsKO(targetplayer)
    if targetplayer and targetplayer.Character and targetplayer.Character:FindFirstChild("BodyEffects") and targetplayer.Character.BodyEffects:FindFirstChild("K.O") and targetplayer.Character.BodyEffects["K.O"].Value then
        return true
    end
    return false
end

function CheckIsDead(targetplayer)
    if not targetplayer then return true end
    if not targetplayer.Character then return true end
    local hum = targetplayer.Character:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return true end
    if not targetplayer.Character:FindFirstChild("HumanoidRootPart") then return true end
    return false
end

function checkwalls(targetplayer)
    if not localplayer.Character or not localplayer.Character:FindFirstChild("HumanoidRootPart") then return true end
    if not targetplayer.Character or not targetplayer.Character:FindFirstChild("HumanoidRootPart") then return true end
    if workspace:FindPartOnRayWithIgnoreList(Ray.new(
        localplayer.Character.HumanoidRootPart.Position, 
        (targetplayer.Character.HumanoidRootPart.Position - localplayer.Character.HumanoidRootPart.Position).Unit * 
        (targetplayer.Character.HumanoidRootPart.Position - localplayer.Character.HumanoidRootPart.Position).Magnitude
    ), {localplayer.Character, targetplayer.Character}) then
        return true
    end
    return false
end

function checkforcefield(targetplayer)
    if targetplayer.Character and targetplayer.Character:FindFirstChildOfClass("ForceField") then
        return true
    end
    return false
end

