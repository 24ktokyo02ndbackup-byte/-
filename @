    if key ~= "Hit" and key ~= "hit" then return oldIndex(self, key) end
    if Hollow.Ragebot.Enabled and CurrentRagebotTarget and CurrentRagebotTarget.Character and CurrentRagebotTarget.Character:FindFirstChild(Hollow.Ragebot.HitPart) then
        return CFrame.new(CurrentRagebotTarget.Character:FindFirstChild(Hollow.Ragebot.HitPart).Position)
    end
    return oldIndex(self, key)
end)
