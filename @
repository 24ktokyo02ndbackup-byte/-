-- Main Loop
RS.RenderStepped:Connect(function()
    if not Hollow.AimAssist.Enabled then return end
    if not LockedOnCam or not CurrentCamTarget then return end
    local character = CurrentCamTarget.Character
    if not character then
        LockedOnCam = false
        CurrentCamTarget = nil
        return
    end
    if Hollow.Checks.KOcheck and CheckIsKO(CurrentCamTarget) then
        LockedOnCam = false
        CurrentCamTarget = nil
        Monitor(false)
        return
    end
    if Hollow.Checks.ForceFieldcheck and checkforcefield(CurrentCamTarget) then
        return
    end
    if Hollow.Checks.Wallcheck and checkwalls(CurrentCamTarget) then
        return
    end

    local hitpart = character:FindFirstChild(Hollow.AimAssist.Hitpart)
    if not hitpart then return end

    local prediction = hitpart.AssemblyLinearVelocity * Hollow.AimAssist.Prediction
    local targetPos = hitpart.Position + prediction
    local smoothing = math.clamp(Hollow.AimAssist.Smoothing, 1, 100)

    Camera.CFrame = Camera.CFrame:Lerp(
        CFrame.new(Camera.CFrame.Position, targetPos),
        1 / smoothing
    )
end)

