        p.Anchored = true
        p.CanCollide = false
        p.CastShadow = false
        p.Material = Enum.Material.ForceField
        p.Color = Color3.fromRGB(255, 255, 255)
        p.Transparency = 0
        p.Parent = workspace
        return { part = p, offset = offset }
    end

    cloneParts.Head     = makePart(Vector3.new(1, 1, 1),   CFrame.new(0, 1.5, 0))
    cloneParts.Torso    = makePart(Vector3.new(2, 2, 1),   CFrame.new(0, 0, 0))
