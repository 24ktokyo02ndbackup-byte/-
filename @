local function CreateBeamTracer(startPos, endPos, lifetime, styleData)
    local beam = Instance.new("Beam")
    for prop, value in pairs(styleData) do beam[prop] = value end
    beam.Color = ColorSequence.new(Hollow.BulletTracers.Color)
    beam.Transparency = NumberSequence.new{
        NumberSequenceKeypoint.new(0, Hollow.BulletTracers.Transparency),
        NumberSequenceKeypoint.new(1, 1)
    }
    local attach0 = Instance.new("Attachment")
    attach0.CFrame = CFrame.new(startPos)
    attach0.Parent = workspace.Terrain
    local attach1 = Instance.new("Attachment")
    attach1.CFrame = CFrame.new(endPos)
    attach1.Parent = workspace.Terrain
    beam.Attachment0 = attach0
    beam.Attachment1 = attach1
    beam.Parent = workspace.Terrain
    local elapsed = 0
    local fadeFunc = function(dt)
        elapsed += dt
        local alpha = math.clamp(elapsed / lifetime, 0, 1)
        beam.Transparency = NumberSequence.new{
            NumberSequenceKeypoint.new(0, Hollow.BulletTracers.Transparency + (1 - Hollow.BulletTracers.Transparency) * alpha),
            NumberSequenceKeypoint.new(1, 1)
        }
    end
    table.insert(BulletTracerHeartbeat, fadeFunc)
    task.delay(lifetime, function()
        for i, fn in ipairs(BulletTracerHeartbeat) do
            if fn == fadeFunc then table.remove(BulletTracerHeartbeat, i) break end
        end
        beam:Destroy()
        attach0:Destroy()
        attach1:Destroy()
    end)
end

local function CreateLineTracer(startPos, endPos, lifetime)
    local transparency = Hollow.BulletTracers.Transparency
    local outline = Drawing.new("Line")
    outline.Color = Color3.new(0, 0, 0)
    outline.Thickness = 3
    outline.Transparency = transparency
    outline.Visible = false

    local line = Drawing.new("Line")
    line.Color = Hollow.BulletTracers.Color
    line.Thickness = 1
    line.Transparency = transparency
    line.Visible = false

    local elapsedTime = 0

    local updateFunction = function(dt)
        if not line or not outline then return end
        elapsedTime += dt

        local screenStart, startOnScreen = Camera:WorldToViewportPoint(startPos)
        local screenEnd, endOnScreen = Camera:WorldToViewportPoint(endPos)

        if not startOnScreen and not endOnScreen then
            line.Visible = false
            outline.Visible = false
            return
        end

        local fromPos = Vector2.new(screenStart.X, screenStart.Y)
        local toPos = Vector2.new(screenEnd.X, screenEnd.Y)

        line.From = fromPos
        line.To = toPos
        outline.From = fromPos
        outline.To = toPos
        line.Visible = true
        outline.Visible = true

        if elapsedTime > lifetime then
            local alpha = math.clamp((elapsedTime - lifetime) / 0.3, 0, 1)
            local newTransparency = transparency + (1 - transparency) * alpha
            line.Transparency = newTransparency
            outline.Transparency = newTransparency
        end
    end

    table.insert(BulletTracerHeartbeat, updateFunction)

    task.delay(lifetime + 0.3, function()
        for i, fn in ipairs(BulletTracerHeartbeat) do
            if fn == updateFunction then table.remove(BulletTracerHeartbeat, i) break end
        end
        line:Remove()
        outline:Remove()
        line = nil
        outline = nil
    end)
end

local function Create_Tracer(startPos, endPos)
    if not Hollow.BulletTracers.Enabled then return end
    local mode = Hollow.BulletTracers.Mode
    local lifetime = Hollow.BulletTracers.Lifetime
    if mode == "Line" then
        CreateLineTracer(startPos, endPos, lifetime)
    elseif BeamStyles[mode] then
        CreateBeamTracer(startPos, endPos, lifetime, BeamStyles[mode])
    end
end

RS.Heartbeat:Connect(function(dt)
    for _, fn in ipairs(BulletTracerHeartbeat) do
        fn(dt)
    end
end)

